# Tip Calculator

# Ask user to enter the bill amount
bill_amount = float(input("Enter the restaurant bill amount: "))

# Decide tip rate
if bill_amount > 500:
    tip_rate = 0.05
elif bill_amount > 100:
    tip_rate = 0.08
else:
    tip_rate = 0.10

# Calculate tip
tip_amount = round(bill_amount * tip_rate)

# Calculate total amount
total_amount = bill_amount + tip_amount

# Display results
print("\n--- Tip Calculator Result ---")
print(f"Bill Amount: ${bill_amount:.2f}")
print(f"Tip Rate: {tip_rate * 100:.0f}%")
print(f"Tip Amount: ${tip_amount}")
print(f"Total Amount: ${total_amount:.2f}")
